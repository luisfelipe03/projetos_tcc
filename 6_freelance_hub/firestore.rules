rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Perfis públicos de usuário. Leitura pública (necessária para
    // exibir nome/avatar do cliente na tela de detalhes do projeto,
    // por exemplo). Criação e atualização restritas ao próprio uid.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.role in ['client', 'freelancer'];
      // Update: SÓ o próprio user, SÓ os campos displayName / photoUrl
      // (perfil editável da Iteração 28). role/email/createdAt imutáveis.
      // fcmTokens é mexido em chamadas separadas (arrayUnion/arrayRemove),
      // que continuam permitidas porque a regra valida diff.affectedKeys —
      // que naquele caso é só ['fcmTokens']. Pra cobrir os 2 casos, listamos
      // o conjunto permitido.
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasOnly(['displayName', 'photoUrl', 'fcmTokens']);
      allow delete: if false;
    }

    // Projetos publicados. Leitura por qualquer usuário autenticado.
    // Criação restrita ao próprio ownerId (com role client validado).
    // Atualização: dono pode editar campos da descrição; status NÃO pode
    // ser alterado direto pelo client — só via Cloud Function (próxima fase).
    // proposalCount também só via Function (incremento atômico ao receber proposta).
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.status == 'open'
                    && request.resource.data.proposalCount == 0;
      allow update: if request.auth != null
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == resource.data.ownerId
                    && request.resource.data.status == resource.data.status
                    && request.resource.data.proposalCount == resource.data.proposalCount;
      allow delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid
                    && resource.data.status == 'open'
                    && resource.data.proposalCount == 0;
    }

    // Propostas. Doc ID = "{projectId}_{freelancerId}" — previne duplicatas.
    // Leitura: só o freelancer dono OU o cliente do projeto.
    // Criação: só pelo próprio freelancer, status pending obrigatório.
    // Update/delete: bloqueado — transições de status são via Cloud Function
    // (aceitar/rejeitar/withdraw acompanha o ciclo de vida do contrato).
    match /proposals/{proposalId} {
      allow read: if request.auth != null
                  && (resource.data.freelancerId == request.auth.uid
                      || resource.data.clientId == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.freelancerId == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update: if false;
      allow delete: if false;
    }

    // Contratos. Criados exclusivamente pela Cloud Function acceptProposal
    // (admin SDK bypassa rules). Leitura: só as partes do contrato.
    // Update/delete: bloqueado — transições de status (entrega, conclusão,
    // disputa) virão por Cloud Function dedicada em iterações futuras.
    match /contracts/{contractId} {
      allow read: if request.auth != null
                  && (resource.data.clientId == request.auth.uid
                      || resource.data.freelancerId == request.auth.uid);
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Avaliações pós-conclusão. Doc ID = "{contractId}_{reviewerId}".
    // Read: público pra qualquer authed (avaliações compõem perfil público).
    // Write/update/delete: bloqueado — só via Cloud Function submitReview
    // (admin SDK bypassa rules; valida caller, status, dedupe, agrega no user).
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Threads de mensagens. Doc ID = "{uidA}_{uidB}" ordenado.
    // Leitura: só os participantes. Create/update via Cloud Function
    // sendMessage (denormaliza nomes e atualiza lastMessage atomicamente).
    match /threads/{threadId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participantIds;
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      // Mensagens da thread. Autorização derivada do threadId
      // ("{uidMenor}_{uidMaior}") em vez de get() na thread — permite abrir
      // a stream antes da primeira mensagem ser enviada (thread ainda não
      // existe), evitando permission-denied no ChatView. UIDs do Firebase
      // Auth não contêm "_", então o split é seguro.
      // Server-side via sendMessage callable; client não escreve direto.
      match /messages/{messageId} {
        allow read: if request.auth != null
                    && (request.auth.uid == threadId.split('_')[0]
                        || request.auth.uid == threadId.split('_')[1]);
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
