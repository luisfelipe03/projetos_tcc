rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Perfis públicos de usuário. Leitura pública (necessária para
    // exibir nome/avatar do cliente na tela de detalhes do projeto,
    // por exemplo). Criação e atualização restritas ao próprio uid.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.role in ['client', 'freelancer'];
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    // role não pode mudar após criação.
                    && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    // Projetos publicados. Leitura por qualquer usuário autenticado.
    // Criação restrita ao próprio ownerId (com role client validado).
    // Atualização: dono pode editar campos da descrição; status NÃO pode
    // ser alterado direto pelo client — só via Cloud Function (próxima fase).
    // proposalCount também só via Function (incremento atômico ao receber proposta).
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.status == 'open'
                    && request.resource.data.proposalCount == 0;
      allow update: if request.auth != null
                    && resource.data.ownerId == request.auth.uid
                    && request.resource.data.ownerId == resource.data.ownerId
                    && request.resource.data.status == resource.data.status
                    && request.resource.data.proposalCount == resource.data.proposalCount;
      allow delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid
                    && resource.data.status == 'open'
                    && resource.data.proposalCount == 0;
    }
  }
}
