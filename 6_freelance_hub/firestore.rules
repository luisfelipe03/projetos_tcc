rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Perfis públicos de usuário. Leitura pública (necessária para
    // exibir nome/avatar do cliente na tela de detalhes do projeto,
    // por exemplo). Criação e atualização restritas ao próprio uid.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.role in ['client', 'freelancer'];
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    // role não pode mudar após criação.
                    && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }
  }
}
