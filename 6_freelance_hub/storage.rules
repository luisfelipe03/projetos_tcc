rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de entrega anexadas pelo freelancer ao marcar contrato como entregue.
    // Path: delivery_photos/{contractId}/{fileName}
    //
    // Leitura: qualquer usuário autenticado. Limitação consciente do MVP:
    // Storage rules não podem ler docs do Firestore, então não dá pra restringir
    // só às partes do contrato sem custom claims ou Cloud Function de download.
    // Aceitável porque os paths usam IDs de contrato não-listáveis (auto-id
    // do Firestore) — só quem tem o ID consegue acessar.
    //
    // Escrita: usuário autenticado + arquivo de imagem + até 5MB.
    // A garantia de que SÓ o freelancer do contrato pode escrever vem do
    // server (a callable markContractDelivered valida caller == freelancerId).
    match /delivery_photos/{contractId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Foto de perfil do user. Path: profile_photos/{uid}/{fileName}.
    //
    // Leitura: pública pra usuário autenticado (avatar aparece em chats,
    // cards de proposta, etc — qualquer parte do app que liste pessoas).
    // Escrita: SÓ o próprio user (o path inclui o uid). 5MB max + image/*.
    match /profile_photos/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
